{
  "name": "nextjs-starter",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build && next-image-export-optimizer",
    "deploy:staging": "yarn build && wrangler pages deploy dist --project-name=eastridge-staging",
    "start": "next start",
    "type-check": "tsc --noEmit",
    "lint": "eslint --ignore-pattern .gitignore \"src/**/*.{ts,js,tsx,jsx}\"",
    "format": "prettier --ignore-pattern .gitignore \"src/**/*.{ts,js,tsx,jsx}\" --write",
    "postinstall": "husky install"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "gsap": "^3.13.0",
    "next": "15.3.8",
    "next-image-export-optimizer": "^1.20.1",
    "react": "19.0.3",
    "react-dom": "19.0.3",
    "react-intersection-observer": "^9.16.0",
    "swiper": "^11.2.10"
  },
  "lint-staged": {
    "./src/**/*.{ts,js,jsx,tsx}": [
      "eslint --ignore-pattern .gitignore --fix",
      "prettier --ignore-pattern .gitignore --write"
    ]
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "19.0.3",
    "@types/react-dom": "19.0.3",
    "@typescript-eslint/eslint-plugin": "^8.6.0",
    "@typescript-eslint/parser": "^8.6.0",
    "eslint": "^9",
    "eslint-config-next": "15.3.8",
    "eslint-config-prettier": "^10.1.2",
    "eslint-import-resolver-typescript": "^4.3.2",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-prettier": "^5.2.6",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.1",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wrangler": "^4.83.0"
  }
}
